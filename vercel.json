{
  "version": 2,
  "buildCommand": "npx prisma generate",
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/routes/**",
          "node_modules/swagger-ui-dist/**",
          "node_modules/.prisma/**",
          "node_modules/@prisma/client/runtime/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/index.ts" }
  ]
}
